<style>
  @font-face { font-family: 'Ballantines'; src: url('{{ 'Ballantines.ttf' | asset_url }}') format('truetype'); font-display: swap; }
  @font-face { font-family: 'Block';       src: url('{{ 'Block.ttf' | asset_url }}') format('truetype'); font-display: swap; }
  @font-face { font-family: 'Katelyn';     src: url('{{ 'Katelyn.ttf' | asset_url }}') format('truetype'); font-display: swap; }
  @font-face { font-family: 'Edwardian';   src: url('{{ 'Edwardian.ttf' | asset_url }}') format('truetype'); font-display: swap; }
  @font-face { font-family: 'Chateauneuf'; src: url('{{ 'Chateauneuf.ttf' | asset_url }}') format('truetype'); font-display: swap; }
  @font-face { font-family: 'Garamond';    src: url('{{ 'Garamond.ttf' | asset_url }}') format('truetype'); font-display: swap; }

  /* 50/50 column split — desktop only */
  @media screen and (min-width: 750px) {
    .product__media-wrapper,
    .product__info-wrapper {
      max-width: 50% !important;
      width: calc(50% - var(--grid-desktop-horizontal-spacing) / 2) !important;
    }
    .product__info-wrapper {
      padding-left: 3rem !important;
    }
  }
</style>

{%- comment -%} Build colors array from the Color variant option {%- endcomment -%}
{%- assign el_color_idx = nil -%}
{%- for o in product.options -%}
  {%- assign o_lower = o | downcase -%}
  {%- if o_lower == 'color' or o_lower == 'colour' or o_lower == 'colors' -%}
    {%- assign el_color_idx = forloop.index0 -%}
  {%- endif -%}
{%- endfor -%}

{%- assign el_colors_arr = '' -%}
{%- if el_color_idx != nil -%}
  {%- assign el_seen = '' -%}
  {%- for v in product.variants -%}
    {%- assign cv = v.options[el_color_idx] -%}
    {%- unless el_seen contains cv -%}
      {%- assign el_seen = el_seen | append: cv | append: '|' -%}
      {%- assign el_media_id = '' -%}
      {%- if v.featured_media != nil -%}{%- assign el_media_id = section.id | append: '-' | append: v.featured_media.id -%}{%- endif -%}
      {%- assign el_img_url = '' -%}
      {%- if v.featured_image != nil -%}{%- assign el_img_url = v.featured_image | image_url: width: 1200 -%}{%- endif -%}
      {%- assign el_hex = v.metafields.custom.color.value | default: '' -%}
      {%- capture el_entry -%}{"name":{{ cv | json }},"available":{{ v.available }},"variantId":{{ v.id }},"mediaId":{{ el_media_id | json }},"imageUrl":{{ el_img_url | json }},"color":{{ el_hex | json }}}{%- endcapture -%}
      {%- if el_colors_arr == '' -%}
        {%- assign el_colors_arr = el_entry -%}
      {%- else -%}
        {%- assign el_colors_arr = el_colors_arr | append: ',' | append: el_entry -%}
      {%- endif -%}
    {%- endunless -%}
  {%- endfor -%}
{%- endif -%}

<div
  id="ember-lane-customizer"
  data-customizer-type="{{ customizer_type }}"
  data-product-title="{{ product.title | escape }}"
  data-current-variant-id="{{ product.selected_or_first_available_variant.id }}"
  data-product-price="{{ product.selected_or_first_available_variant.price | money }}"
  data-canvas-image="{{ product.featured_image | image_url: width: 800 }}"
  data-canvas-bg-color="{{ product.metafields.custom.canvas_bg_color.value | default: product.metafields.custom.canvas_bg_color | default: '#F5F3EF' }}"
  data-max-motifs="{{ product.metafields.custom.max_motifs.value | default: product.metafields.custom.max_motifs | default: 3 }}"
  data-category-label="{{ product.metafields.custom.category_label.value | default: product.metafields.custom.category_label | default: 'Bespoke Customization' }}"
  data-tagline="{{ product.metafields.custom.tagline.value | default: product.metafields.custom.tagline | escape }}"
  data-description="{{ product.description | strip_html | truncate: 300 | escape }}"
  data-founder-quote="{{ product.metafields.custom.founder_quote.value | default: product.metafields.custom.founder_quote | escape }}"
  data-founder-name="{{ product.metafields.custom.founder_name.value | default: product.metafields.custom.founder_name | escape }}"
  data-feature-1="{{ product.metafields.custom.feature_1.value | default: product.metafields.custom.feature_1 }}"
  data-feature-2="{{ product.metafields.custom.feature_2.value | default: product.metafields.custom.feature_2 }}"
  data-feature-3="{{ product.metafields.custom.feature_3.value | default: product.metafields.custom.feature_3 }}"
  data-cover-media-id="{{ section.id }}-{{ product.featured_media.id }}"
  data-color-option="{{ product.options | join: ',' | escape }}"
  data-colors="{{ '[' | append: el_colors_arr | append: ']' | escape }}"
></div>
<script src="{{ 'customizer-bundle.js' | asset_url }}" defer="defer"></script>
